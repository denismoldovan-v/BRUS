# =============================================================================
# AI Security Demo — Local-only configuration
# =============================================================================
# No paid or cloud LLM API keys are required or used:
#   OPENAI_API_KEY, ANTHROPIC_API_KEY, GOOGLE_GENERATIVE_AI_API_KEY,
#   XAI_API_KEY, AI_GATEWAY_API_KEY — none of these are read by this app.
# All chat inference is routed through Ollama on localhost.
# =============================================================================

# Authentication — generate with: openssl rand -base64 32
AUTH_SECRET=****

# Local Ollama configuration (no paid API keys required)
# Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Default chat model — must be pulled locally: ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# Optional: comma-separated additional models to show in the UI
# OLLAMA_EXTRA_MODELS=mistral,codellama

# Force mock AI responses (skips Ollama entirely — useful for UI development)
USE_MOCK_AI=0

# PostgreSQL database for chat history and user data
POSTGRES_URL=****

# Optional: Redis for rate limiting and stream resumption
# REDIS_URL=****

# Optional: Vercel Blob for file uploads (leave unset to disable uploads in local dev)
# BLOB_READ_WRITE_TOKEN=****

# Optional: demo mode (serves app under /demo path)
# IS_DEMO=0
